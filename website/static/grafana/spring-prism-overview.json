  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "text",
      "title": "How To Use This Dashboard",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "content": "Import this dashboard after installing the Grafana Infinity datasource. Then update the hidden `prism_endpoint` variable to point at `/actuator/prism` or `/prism/metrics` on the node you want to inspect. This starter dashboard is intentionally node-level and works best alongside Prometheus infrastructure dashboards.",
        "mode": "markdown"
      },
      "transparent": true
    },
    {
      "type": "stat",
      "title": "Privacy Score",
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "${DS_PRISM_INFINITY}"
      },
      "gridPos": {
        "h": 7,
        "w": 4,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "green",
                "value": 90
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "yesoreyeram-infinity-datasource",
            "uid": "${DS_PRISM_INFINITY}"
          },
          "format": "table",
          "parser": "uql",
          "refId": "A",
          "source": "url",
          "type": "json",
          "url": "${prism_endpoint}",
          "uql": "parse-json | project score=tonumber(\"privacyScore.score\")"
        }
      ]
    },
    {
